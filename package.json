{
  "name": "@braudypedrosa/bp-ui-components",
  "version": "0.1.0",
  "description": "Framework-agnostic bp-ui component library with vanilla JS and Alpine adapters.",
  "author": "Braudy Pedrosa",
  "type": "module",
  "main": "./dist/bp-ui.js",
  "module": "./dist/bp-ui.js",
  "exports": {
    ".": "./dist/bp-ui.js",
    "./styles": "./dist/styles/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "rm -rf dist && vite build && mkdir -p dist/styles && cp src/styles/index.css dist/styles/index.css && cp src/styles/counter.css dist/styles/counter.css"
  },
  "keywords": [
    "ui",
    "components",
    "counter",
    "design-system",
    "vanilla-js",
    "alpinejs",
    "tailwind"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braudypedrosa/bp-ui-components.git"
  },
  "bugs": {
    "url": "https://github.com/braudypedrosa/bp-ui-components/issues"
  },
  "homepage": "https://github.com/braudypedrosa/bp-ui-components#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "vite": "^6.2.4",
    "vitest": "^3.1.1"
  }
}
